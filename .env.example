# Slack 설정
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_CHANNEL=C0XXXXXXXXX

# Google Maps API (지오코딩)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# 알림 반경 (미터)
PROXIMITY_RADIUS_METERS=500

# 고정 위치 (설정 시 IP 기반 위치 대신 사용)
# HOME_LAT=37.4878
# HOME_LNG=126.9803

# 옵시디언 볼트 (vault MCP 서버)
VAULT_DIR=C:/My Gdrive Vault
# git commit+push 동기화 (1=켬, 0=끔 — 로컬 테스트 시 0)
VAULT_GIT_SYNC=1
